rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ------------------------------------------------------------
    // ENTITY VALIDATORS
    // ------------------------------------------------------------
    
    function isValidUserProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 5 && data.email.size() < 100 &&
             (data.get('title', '') is string) &&
             (data.get('location', '') is string) &&
             (data.get('phone', '') is string) &&
             (data.get('linkedin', '') is string) &&
             (data.get('portfolio', '') is string) &&
             (data.get('cvHighlights', '') is string);
    }

    function isValidUserPreferences(data) {
      return data.roles is list && (data.roles.size() == 0 || data.roles[0] is string) &&
             data.location is string &&
             data.salary is string &&
             data.type is string;
    }

    function isValidSchedule(data) {
      return data.role is string && data.role.size() > 0 &&
             data.frequency in ['daily', 'weekly', 'hourly'] &&
             data.cronExpression is string &&
             data.active is bool &&
             data.createdAt == request.time;
    }

    function isValidExecution(data) {
      return data.scheduleId is string &&
             data.timestamp == request.time &&
             data.status in ['success', 'failure', 'running'] &&
             data.logs is list &&
             data.resultCount is number;
    }

    function isValidApplication(data) {
      return data.title is string && data.title.size() > 0 &&
             data.company is string && data.company.size() > 0 &&
             data.date is string &&
             data.status is string &&
             (data.get('sentTo', '') is string);
    }

    // ------------------------------------------------------------
    // ACCESS RULES
    // ------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming()) && incoming().keys().hasAll(['name', 'email']);
      allow update: if isOwner(userId) && isValidUserProfile(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'title', 'location', 'email', 'phone', 'linkedin', 'portfolio', 'cvHighlights']);

      match /preferences/main {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidUserPreferences(incoming());
      }

      match /schedules/{scheduleId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(scheduleId) && isValidSchedule(incoming());
        allow update: if isOwner(userId) && isValidSchedule(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['role', 'frequency', 'cronExpression', 'active']);
        allow delete: if isOwner(userId);
      }

      match /executions/{executionId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(executionId) && isValidExecution(incoming()) && 
                      get(/databases/$(database)/documents/users/$(userId)/schedules/$(incoming().scheduleId)) != null;
        allow update: if isOwner(userId) && existing().status == 'running' && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'logs', 'resultCount']) &&
                      isValidExecution(incoming());
        allow delete: if isOwner(userId);
      }

      match /applications/{applicationId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(applicationId) && isValidApplication(incoming());
        allow update: if isOwner(userId) && isValidApplication(incoming()) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'company', 'date', 'status', 'sentTo']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
